# Godot 4+ specific ignores
.godot/
/android/
__pycache__/
.env
*.env
assets/sprites/player/*_bak_*.png

# Screenshots de teste gerados pelo harness do Godot (regeraveis)
tools/art_director/iterations/godot_shots/

# Soph HD regen workspace (staging/backup/preview/raw)
assets/sprites/player/_backup_pre_regen/
assets/sprites/player/_pending_regen/
assets/sprites/player/_preview/
assets/sprites/player/_raw/

# Diagnostic comparison images
docs/concept_art/diag/

# Cache local pesado (vive em D:\Projetos\great-fireball-local-cache\)
# Mantido fora do repo pra nao inflar historico; reextrair via tools/rig/.
tools/rig/_video_frames/

# Claude Code runtime
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Godot import sidecars dos artefatos da art-pipeline (nao sao assets do jogo)
tools/art_director/iterations/**/*.import
tools/rig3d/out/**
# Excecoes: precisa "abrir" diretorios pai pra permitir negacao do arquivo
!tools/rig3d/out/dream_rig/
!tools/rig3d/out/dream_rig/walk_test/
!tools/rig3d/out/dream_rig/idle_test/
# Deliverables visuais: GIFs do walk/idle cycles (Soph com pano e cabelo)
!tools/rig3d/out/dream_rig/walk_test/*.gif
!tools/rig3d/out/dream_rig/idle_test/*.gif
# Anim PRO retargetada (Mixamo via DESVIO + aducao de braco) — bracos abaixados
!tools/rig3d/out/dream_rig/walk_pro/
!tools/rig3d/out/dream_rig/idle_pro/
!tools/rig3d/out/dream_rig/walk_pro/*.gif
!tools/rig3d/out/dream_rig/idle_pro/*.gif
# Demais poses PRO (run/jump/cast/slash/hurt) — cloth bake em cima da anim
!tools/rig3d/out/dream_rig/run_pro/
!tools/rig3d/out/dream_rig/jump_pro/
!tools/rig3d/out/dream_rig/cast_pro/
!tools/rig3d/out/dream_rig/slash_pro/
!tools/rig3d/out/dream_rig/hurt_pro/
!tools/rig3d/out/dream_rig/run_pro/*.gif
!tools/rig3d/out/dream_rig/jump_pro/*.gif
!tools/rig3d/out/dream_rig/cast_pro/*.gif
!tools/rig3d/out/dream_rig/slash_pro/*.gif
!tools/rig3d/out/dream_rig/hurt_pro/*.gif
tools/art_director/iterations/goblin/
tools/art_director/iterations/golem/
tools/art_director/iterations/mago/

# Soph3D re-rig Mixamo: intermediarios/working files (cache local).
# DELIVERABLE versionado = soph_textured_rigged.glb (textura 4K + rig Mixamo c/ dedos).
tools/rig3d/in/soph_for_mixamo.fbx
tools/rig3d/in/soph_mixamo_rigged.fbx
tools/rig3d/in/soph_rig_wip.blend
# Godot extrai sidecars/texturas dos GLB ao importar -- derivados (o .glb e o deliverable)
tools/rig3d/in/*.import
tools/rig3d/in/*_texture_pbr_*.png
tools/rig3d/in/*_normal.png
tools/rig3d/in/*_roughness.png
tools/rig3d/in/*_Material_*.png
tools/rig3d/in/*.png

# Backup automatico do Blender (.blend1) — sempre regenerado, polui o repo
tools/rig3d/in/*.blend1
